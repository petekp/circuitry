    "blocks": [
      {
        "step_id": "frame-step",
        "title": "Frame - confirm Build brief",
        "kind": "checkpoint",
        "executor": "orchestrator",
        "protocol": "build-frame@v1",
        "reads": [],
        "writes": {
          "request": "reports/checkpoints/frame-step-request.json",
          "response": "reports/checkpoints/frame-step-response.json",
          "report": {
            "path": "reports/build/brief.json",
            "schema": "build.brief@v1"
          }
        },
        "check": {
          "kind": "checkpoint_selection",
          "source": {
            "kind": "checkpoint_response",
            "ref": "response"
          },
          "allow": ["continue"]
        },
        "routes": {
          "continue": "plan-step",
          "pass": "plan-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "plan-step",
        "title": "Plan - produce Build plan",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "build-plan@v1",
        "reads": ["reports/build/brief.json"],
        "writes": {
          "report": {
            "path": "reports/build/plan.json",
            "schema": "build.plan@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["objective", "verification"]
        },
        "routes": {
          "continue": "act-step",
          "pass": "act-step",
          "revise": "plan-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "act-step",
        "title": "Act - implementation relay",
        "kind": "relay",
        "executor": "worker",
        "protocol": "build-act@v1",
        "reads": ["reports/build/brief.json", "reports/build/plan.json"],
        "writes": {
          "report": {
            "path": "reports/build/implementation.json",
            "schema": "build.implementation@v1"
          },
          "request": "reports/relay/build-act.request.json",
          "receipt": "reports/relay/build-act.receipt.txt",
          "result": "reports/relay/build-act.result.json"
        },
        "check": {
          "kind": "result_verdict",
          "source": {
            "kind": "relay_result",
            "ref": "result"
          },
          "pass": ["accept"]
        },
        "routes": {
          "continue": "verify-step",
          "pass": "verify-step",
          "retry": "act-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "verify-step",
        "title": "Verify - run Build verification",
        "kind": "verification",
        "executor": "orchestrator",
        "protocol": "build-verify@v1",
        "reads": ["reports/build/plan.json", "reports/build/implementation.json"],
        "writes": {
          "report": {
            "path": "reports/build/verification.json",
            "schema": "build.verification@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["overall_status", "commands"]
        },
        "routes": {
          "continue": "review-step",
          "pass": "review-step",
          "retry": "act-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "review-step",
        "title": "Review - implementation review relay",
        "kind": "relay",
        "executor": "worker",
        "protocol": "build-review@v1",
        "reads": [
          "reports/build/brief.json",
          "reports/build/plan.json",
          "reports/build/implementation.json",
          "reports/build/verification.json"
        ],
        "writes": {
          "report": {
            "path": "reports/build/review.json",
            "schema": "build.review@v1"
          },
          "request": "reports/relay/build-review.request.json",
          "receipt": "reports/relay/build-review.receipt.txt",
          "result": "reports/relay/build-review.result.json"
        },
        "check": {
          "kind": "result_verdict",
          "source": {
            "kind": "relay_result",
            "ref": "result"
          },
          "pass": ["accept", "accept-with-fixes"]
        },
        "routes": {
          "continue": "close-step",
          "pass": "close-step",
          "retry": "act-step",
          "revise": "act-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "close-step",
        "title": "Close - emit Build result",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "build-close@v1",
        "reads": [
          "reports/build/brief.json",
          "reports/build/plan.json",
          "reports/build/implementation.json",
          "reports/build/verification.json",
          "reports/build/review.json"
        ],
        "writes": {
          "report": {
            "path": "reports/build-result.json",
            "schema": "build.result@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["summary", "outcome", "evidence_links"]
        },
        "routes": {
          "complete": "@complete",
          "pass": "@complete",
          "stop": "@stop"
        }
      }
