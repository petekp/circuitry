        "allowed_rigors": ["lite", "standard", "deep"],
        "supports_tournament": false,
        "supports_autonomous": true,
        "default": {
          "rigor": "standard",
          "tournament": false,
          "tournament_n": 3,
          "autonomous": false
        }
      },
      "starts_at": "frame-step"
    },
