    "blocks": [
      {
        "step_id": "frame-step",
        "title": "Frame - define Prototype boundary",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "prototype-frame@v1",
        "reads": [],
        "writes": {
          "report": {
            "path": "reports/prototype/brief.json",
            "schema": "prototype.brief@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["objective", "prototype_root", "claim_limits"]
        },
        "routes": {
          "continue": "plan-step",
          "pass": "plan-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "plan-step",
        "title": "Plan - choose disposable artifact files",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "prototype-plan@v1",
        "reads": ["reports/prototype/brief.json"],
        "writes": {
          "report": {
            "path": "reports/prototype/plan.json",
            "schema": "prototype.plan@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["objective", "files_to_create", "verification"]
        },
        "routes": {
          "continue": "act-step",
          "pass": "act-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "act-step",
        "title": "Act - create disposable prototype artifact",
        "kind": "relay",
        "executor": "worker",
        "protocol": "prototype-act@v1",
        "reads": ["reports/prototype/brief.json", "reports/prototype/plan.json"],
        "writes": {
          "report": {
            "path": "reports/prototype/artifact.json",
            "schema": "prototype.artifact@v1"
          },
          "request": "reports/relay/prototype-act.request.json",
          "receipt": "reports/relay/prototype-act.receipt.txt",
          "result": "reports/relay/prototype-act.result.json"
        },
        "check": {
          "kind": "result_verdict",
          "source": {
            "kind": "relay_result",
            "ref": "result"
          },
          "pass": ["accept"]
        },
        "routes": {
          "continue": "verify-step",
          "pass": "verify-step",
          "stop": "close-step"
        }
      },
      {
        "step_id": "verify-step",
        "title": "Verify - check Prototype artifact integrity",
        "kind": "verification",
        "executor": "orchestrator",
        "protocol": "prototype-verify@v1",
        "reads": ["reports/prototype/plan.json", "reports/prototype/artifact.json"],
        "writes": {
          "report": {
            "path": "reports/prototype/verification.json",
            "schema": "prototype.verification@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["overall_status", "commands"]
        },
        "routes": {
          "continue": "prototype-checkpoint-step",
          "pass": "prototype-checkpoint-step",
          "stop": "close-step"
        }
      },
      {
        "step_id": "prototype-checkpoint-step",
        "title": "Review - decide Prototype disposition",
        "kind": "checkpoint",
        "executor": "orchestrator",
        "protocol": "prototype-checkpoint@v1",
        "reads": ["reports/prototype/artifact.json", "reports/prototype/verification.json"],
        "writes": {
          "request": "reports/checkpoints/prototype-review-request.json",
          "response": "reports/checkpoints/prototype-review-response.json"
        },
        "check": {
          "kind": "checkpoint_selection",
          "source": {
            "kind": "checkpoint_response",
            "ref": "response"
          },
          "allow": ["keep-prototype", "save-build-input", "discard-prototype"]
        },
        "routes": {
          "continue": "close-step",
          "pass": "close-step",
          "stop": "@stop",
          "keep-prototype": "close-step",
          "save-build-input": "close-step",
          "discard-prototype": "close-step"
        }
      },
      {
        "step_id": "close-step",
        "title": "Close - emit Prototype result",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "prototype-close@v1",
        "reads": [
          "reports/prototype/brief.json",
          "reports/prototype/plan.json",
          "reports/prototype/artifact.json"
        ],
        "writes": {
          "report": {
            "path": "reports/prototype-result.json",
            "schema": "prototype.result@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["summary", "outcome", "evidence_links"]
        },
        "routes": {
          "complete": "@complete",
          "pass": "@complete",
          "stop": "@stop"
        }
      }
    ],
    "authority": {
