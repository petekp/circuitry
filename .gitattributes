# Enforce LF line endings on every text file. Without this, Windows
# checkouts pick up CRLF and biome's formatter rejects every file in
# the repo, breaking the windows-latest CI matrix slot.
* text=auto eol=lf

# Generated plugin surfaces — keep linguist out of the repo language stats
# and signal "this is generated" to GitHub diff views. The source of truth
# lives under src/flows/<id>/ and src/commands/. The emit script
# (`npm run emit-flows`) writes the generated outputs.

plugins/claude/commands/*.md linguist-generated=true
plugins/claude/runtime/circuit.js linguist-generated=true
plugins/claude/skills/**/*.json linguist-generated=true

plugins/codex/commands/*.md linguist-generated=true
plugins/codex/flows/**/*.json linguist-generated=true
plugins/codex/runtime/circuit.js linguist-generated=true
plugins/codex/skills/**/SKILL.md linguist-generated=true

generated/flows/**/*.json linguist-generated=true

# Release proof fixtures captured by scripts/release/capture-*.mjs.
docs/release/proofs/runs/** linguist-generated=true
