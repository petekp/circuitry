{
  "schema_version": "2",
  "id": "goal",
  "version": "0.1.0",
  "purpose": "Goal flow. Circuit writes a bounded goal contract, runs one statically authored child flow target, evaluates evidence, runs a two-pass safety review, and closes from typed Goal reports.",
  "entry": {
    "signals": {
      "include": ["goal", "supervise"],
      "exclude": []
    },
    "intent_prefixes": ["goal", "supervise"]
  },
  "axes": {
    "allowed_rigors": ["lite", "standard", "deep"],
    "supports_tournament": false,
    "supports_autonomous": true,
    "default": {
      "rigor": "standard",
      "tournament": false,
      "tournament_n": 3,
      "autonomous": false
    }
  },
  "starts_at": "clarify-goal",
  "stages": [
    {
      "id": "goal-frame-stage",
      "title": "Frame",
      "canonical": "frame",
      "steps": ["clarify-goal", "goal-contract"]
    },
    {
      "id": "goal-act-stage",
      "title": "Act",
      "canonical": "act",
      "steps": [
        "goal-run-fix",
        "goal-run-build",
        "goal-run-review",
        "goal-run-explore",
        "goal-run-pursue",
        "goal-attempt"
      ]
    },
    {
      "id": "goal-verify-stage",
      "title": "Verify",
      "canonical": "verify",
      "steps": ["goal-evidence-evaluation", "goal-recovery", "goal-recovery-checkpoint"]
    },
    {
      "id": "goal-review-stage",
      "title": "Review",
      "canonical": "review",
      "steps": ["goal-gate-pass-1", "goal-gate-pass-2"]
    },
    {
      "id": "goal-close-stage",
      "title": "Close",
      "canonical": "close",
      "steps": ["goal-close"]
    }
  ],
  "stage_path_policy": {
    "mode": "partial",
    "omits": ["analyze", "plan"],
    "rationale": "Goal supervises a child flow through Frame, Act, Verify, Review, and Close. Analyze and Plan are delegated to the selected static child flow."
  },
  "steps": [
    {
      "id": "clarify-goal",
      "title": "Clarify - shape Goal task",
      "protocol": "goal-clarify@v1",
      "reads": [],
      "routes": {
        "continue": "goal-contract",
        "pass": "goal-contract",
        "ask": "@stop",
        "stop": "@stop"
      },
      "route_from_report": {
        "path": ["verdict"]
      },
      "executor": "worker",
      "kind": "relay",
      "role": "researcher",
      "writes": {
        "report": {
          "path": "reports/goal/clarified-task.json",
          "schema": "goal.clarified-task@v1"
        },
        "request": "reports/relay/goal-clarify.request.json",
        "receipt": "reports/relay/goal-clarify.receipt.txt",
        "result": "reports/relay/goal-clarify.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["continue", "ask", "stop"]
      }
    },
    {
      "id": "goal-contract",
      "title": "Goal - write contract and select static target",
      "protocol": "goal-contract@v1",
      "reads": ["reports/goal/clarified-task.json"],
      "routes": {
        "continue": "goal-run-build",
        "pass": "goal-run-build",
        "fix": "goal-run-fix",
        "build": "goal-run-build",
        "review": "goal-run-review",
        "explore": "goal-run-explore",
        "pursue": "goal-run-pursue",
        "ask": "goal-recovery-checkpoint",
        "stop": "@stop"
      },
      "route_from_report": {
        "path": ["selected_flow_target"]
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/goal/contract.json",
          "schema": "goal.contract@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["schema", "objective", "done_when", "selected_flow_target"]
      }
    },
    {
      "id": "goal-run-fix",
      "title": "Child Flow - run Fix",
      "protocol": "goal-run-fix@v1",
      "reads": ["reports/goal/contract.json"],
      "routes": {
        "continue": "goal-attempt",
        "pass": "goal-attempt",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "sub-run",
      "flow_ref": {
        "flow_id": "fix",
        "entry_mode": "default"
      },
      "goal": "Execute the selected child flow for reports/goal/contract.json. Preserve the operator objective and produce a report-backed proof packet.",
      "depth": "standard",
      "writes": {
        "result": "reports/goal/child-results/fix-result.json",
        "report": {
          "path": "reports/goal/child-results/fix-result.json",
          "schema": "goal.child-fix-result@v1"
        }
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "sub_run_result",
          "ref": "result"
        },
        "pass": [
          "accept",
          "accept-with-fixes",
          "accept-with-fold-ins",
          "NO_ISSUES_FOUND",
          "ISSUES_FOUND",
          "clean",
          "needs-followup",
          "decided"
        ]
      }
    },
    {
      "id": "goal-run-build",
      "title": "Child Flow - run Build",
      "protocol": "goal-run-build@v1",
      "reads": ["reports/goal/contract.json"],
      "routes": {
        "continue": "goal-attempt",
        "pass": "goal-attempt",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "sub-run",
      "flow_ref": {
        "flow_id": "build",
        "entry_mode": "default"
      },
      "goal": "Execute the selected child flow for reports/goal/contract.json. Preserve the operator objective and produce a report-backed proof packet.",
      "depth": "standard",
      "writes": {
        "result": "reports/goal/child-results/build-result.json",
        "report": {
          "path": "reports/goal/child-results/build-result.json",
          "schema": "goal.child-build-result@v1"
        }
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "sub_run_result",
          "ref": "result"
        },
        "pass": [
          "accept",
          "accept-with-fixes",
          "accept-with-fold-ins",
          "NO_ISSUES_FOUND",
          "ISSUES_FOUND",
          "clean",
          "needs-followup",
          "decided"
        ]
      }
    },
    {
      "id": "goal-run-review",
      "title": "Child Flow - run Review",
      "protocol": "goal-run-review@v1",
      "reads": ["reports/goal/contract.json"],
      "routes": {
        "continue": "goal-attempt",
        "pass": "goal-attempt",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "sub-run",
      "flow_ref": {
        "flow_id": "review",
        "entry_mode": "default"
      },
      "goal": "Execute the selected child flow for reports/goal/contract.json. Preserve the operator objective and produce a report-backed proof packet.",
      "depth": "standard",
      "writes": {
        "result": "reports/goal/child-results/review-result.json",
        "report": {
          "path": "reports/goal/child-results/review-result.json",
          "schema": "goal.child-review-result@v1"
        }
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "sub_run_result",
          "ref": "result"
        },
        "pass": [
          "accept",
          "accept-with-fixes",
          "accept-with-fold-ins",
          "NO_ISSUES_FOUND",
          "ISSUES_FOUND",
          "clean",
          "needs-followup",
          "decided"
        ]
      }
    },
    {
      "id": "goal-run-explore",
      "title": "Child Flow - run Explore",
      "protocol": "goal-run-explore@v1",
      "reads": ["reports/goal/contract.json"],
      "routes": {
        "continue": "goal-attempt",
        "pass": "goal-attempt",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "sub-run",
      "flow_ref": {
        "flow_id": "explore",
        "entry_mode": "default"
      },
      "goal": "Execute the selected child flow for reports/goal/contract.json. Preserve the operator objective and produce a report-backed proof packet.",
      "depth": "standard",
      "writes": {
        "result": "reports/goal/child-results/explore-result.json",
        "report": {
          "path": "reports/goal/child-results/explore-result.json",
          "schema": "goal.child-explore-result@v1"
        }
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "sub_run_result",
          "ref": "result"
        },
        "pass": [
          "accept",
          "accept-with-fixes",
          "accept-with-fold-ins",
          "NO_ISSUES_FOUND",
          "ISSUES_FOUND",
          "clean",
          "needs-followup",
          "decided"
        ]
      }
    },
    {
      "id": "goal-run-pursue",
      "title": "Child Flow - run Pursue",
      "protocol": "goal-run-pursue@v1",
      "reads": ["reports/goal/contract.json"],
      "routes": {
        "continue": "goal-attempt",
        "pass": "goal-attempt",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "sub-run",
      "flow_ref": {
        "flow_id": "pursue",
        "entry_mode": "default"
      },
      "goal": "Execute the selected child flow for reports/goal/contract.json. Preserve the operator objective and produce a report-backed proof packet.",
      "depth": "standard",
      "writes": {
        "result": "reports/goal/child-results/pursue-result.json",
        "report": {
          "path": "reports/goal/child-results/pursue-result.json",
          "schema": "goal.child-pursue-result@v1"
        }
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "sub_run_result",
          "ref": "result"
        },
        "pass": [
          "accept",
          "accept-with-fixes",
          "accept-with-fold-ins",
          "NO_ISSUES_FOUND",
          "ISSUES_FOUND",
          "clean",
          "needs-followup",
          "decided"
        ]
      }
    },
    {
      "id": "goal-attempt",
      "title": "Attempt - summarize child result",
      "protocol": "goal-attempt@v1",
      "reads": ["reports/goal/contract.json"],
      "routes": {
        "continue": "goal-evidence-evaluation",
        "pass": "goal-evidence-evaluation",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/goal/attempts/attempt-1.json",
          "schema": "goal.attempt@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["schema", "attempt_id", "flow_target", "outcome"]
      }
    },
    {
      "id": "goal-evidence-evaluation",
      "title": "Evaluate - compare attempt evidence to done claims",
      "protocol": "goal-evidence-evaluation@v1",
      "reads": ["reports/goal/contract.json", "reports/goal/attempts/attempt-1.json"],
      "routes": {
        "continue": "goal-gate-pass-1",
        "pass": "goal-gate-pass-1",
        "completion-gate": "goal-gate-pass-1",
        "retry-selected-flow": "goal-recovery",
        "run-fix": "goal-recovery",
        "run-review": "goal-recovery",
        "run-explore": "goal-recovery",
        "split-to-pursue": "goal-recovery",
        "checkpoint": "goal-recovery",
        "handoff": "@handoff",
        "blocked": "goal-recovery",
        "stop": "@stop"
      },
      "route_from_report": {
        "path": ["next_route"]
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/goal/evidence-evaluation.json",
          "schema": "goal.evidence-evaluation@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["schema", "verdict", "claim_results", "next_route"]
      }
    },
    {
      "id": "goal-recovery",
      "title": "Recovery - choose typed next action",
      "protocol": "goal-recovery@v1",
      "reads": ["reports/goal/evidence-evaluation.json", "reports/goal/attempts/attempt-1.json"],
      "routes": {
        "continue": "goal-recovery-checkpoint",
        "pass": "goal-recovery-checkpoint",
        "retry-selected-flow": "goal-recovery-checkpoint",
        "run-fix": "goal-recovery-checkpoint",
        "run-review": "goal-recovery-checkpoint",
        "run-explore": "goal-recovery-checkpoint",
        "split-to-pursue": "goal-recovery-checkpoint",
        "checkpoint": "goal-recovery-checkpoint",
        "blocked": "goal-close",
        "handoff": "@handoff",
        "stop": "@stop"
      },
      "route_from_report": {
        "path": ["selected_route"]
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/goal/recovery.json",
          "schema": "goal.recovery@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["schema", "reason", "selected_route", "rationale"]
      }
    },
    {
      "id": "goal-recovery-checkpoint",
      "title": "Checkpoint - operator judgment required",
      "protocol": "goal-recovery-checkpoint@v1",
      "reads": ["reports/goal/recovery.json"],
      "routes": {
        "continue": "goal-close",
        "pass": "goal-close",
        "blocked": "goal-close",
        "handoff": "@handoff",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "checkpoint",
      "policy": {
        "prompt": "Goal needs operator judgment before continuing.",
        "choices": [
          {
            "id": "continue",
            "label": "Continue"
          },
          {
            "id": "blocked",
            "label": "Close Blocked"
          },
          {
            "id": "handoff",
            "label": "Hand Off"
          }
        ],
        "safe_default_choice": "blocked",
        "safe_autonomous_choice": "blocked"
      },
      "writes": {
        "request": "reports/checkpoints/goal-recovery-request.json",
        "response": "reports/checkpoints/goal-recovery-response.json"
      },
      "check": {
        "kind": "checkpoint_selection",
        "source": {
          "kind": "checkpoint_response",
          "ref": "response"
        },
        "allow": ["continue", "blocked", "handoff"]
      }
    },
    {
      "id": "goal-gate-pass-1",
      "title": "Safety review - pass 1",
      "protocol": "goal-gate-pass-1@v1",
      "reads": ["reports/goal/contract.json", "reports/goal/evidence-evaluation.json"],
      "routes": {
        "continue": "goal-gate-pass-2",
        "pass": "goal-gate-pass-2",
        "retry": "goal-recovery",
        "stop": "@stop"
      },
      "executor": "worker",
      "kind": "relay",
      "role": "reviewer",
      "writes": {
        "report": {
          "path": "reports/goal/gate-pass-1.json",
          "schema": "goal.gate-pass@v1"
        },
        "request": "reports/relay/goal-gate-pass-1.request.json",
        "receipt": "reports/relay/goal-gate-pass-1.receipt.txt",
        "result": "reports/relay/goal-gate-pass-1.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["gate-pass"]
      }
    },
    {
      "id": "goal-gate-pass-2",
      "title": "Safety review - pass 2",
      "protocol": "goal-gate-pass-2@v1",
      "reads": [
        "reports/goal/contract.json",
        "reports/goal/evidence-evaluation.json",
        "reports/goal/gate-pass-1.json"
      ],
      "routes": {
        "continue": "goal-close",
        "pass": "goal-close",
        "retry": "goal-recovery",
        "stop": "@stop"
      },
      "executor": "worker",
      "kind": "relay",
      "role": "reviewer",
      "writes": {
        "report": {
          "path": "reports/goal/gate.json",
          "schema": "goal.gate@v1"
        },
        "request": "reports/relay/goal-gate-pass-2.request.json",
        "receipt": "reports/relay/goal-gate-pass-2.receipt.txt",
        "result": "reports/relay/goal-gate-pass-2.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["gate-pass"]
      }
    },
    {
      "id": "goal-close",
      "title": "Close - emit Goal result",
      "protocol": "goal-close@v1",
      "reads": [
        "reports/goal/contract.json",
        "reports/goal/attempts/attempt-1.json",
        "reports/goal/evidence-evaluation.json",
        "reports/goal/recovery.json",
        "reports/goal/gate.json"
      ],
      "routes": {
        "complete": "@complete",
        "pass": "@complete",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/goal-result.json",
          "schema": "goal.result@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["schema", "outcome", "summary", "evidence_links", "gate"]
      }
    }
  ]
}
