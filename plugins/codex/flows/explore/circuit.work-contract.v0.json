    "blocks": [
      {
        "step_id": "frame-step",
        "title": "Frame — produce explore.brief",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-frame@v1",
        "reads": [],
        "writes": {
          "report": {
            "path": "reports/brief.json",
            "schema": "explore.brief@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["subject", "success_condition"]
        },
        "routes": {
          "continue": "analyze-step",
          "pass": "analyze-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "analyze-step",
        "title": "Analyze — produce explore.analysis",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-analyze@v1",
        "reads": ["reports/brief.json"],
        "writes": {
          "report": {
            "path": "reports/analysis.json",
            "schema": "explore.analysis@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["aspects"]
        },
        "routes": {
          "continue": "synthesize-step",
          "pass": "synthesize-step",
          "retry": "analyze-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "synthesize-step",
        "title": "Synthesize — produce explore.compose (connector-bound relay)",
        "kind": "relay",
        "executor": "worker",
        "protocol": "explore-synthesize@v1",
        "reads": ["reports/brief.json", "reports/analysis.json"],
        "writes": {
          "report": {
            "path": "reports/compose.json",
            "schema": "explore.compose@v1"
          },
          "request": "reports/relay/synthesize.request.json",
          "receipt": "reports/relay/synthesize.receipt.txt",
          "result": "reports/relay/synthesize.result.json"
        },
        "check": {
          "kind": "result_verdict",
          "source": {
            "kind": "relay_result",
            "ref": "result"
          },
          "pass": ["accept"]
        },
        "routes": {
          "continue": "review-step",
          "pass": "review-step",
          "retry": "synthesize-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "review-step",
        "title": "Review — adversarial pass over compose (connector-bound relay)",
        "kind": "relay",
        "executor": "worker",
        "protocol": "explore-review@v1",
        "reads": ["reports/brief.json", "reports/analysis.json", "reports/compose.json"],
        "writes": {
          "report": {
            "path": "reports/review-verdict.json",
            "schema": "explore.review-verdict@v1"
          },
          "request": "reports/relay/review.request.json",
          "receipt": "reports/relay/review.receipt.txt",
          "result": "reports/relay/review.result.json"
        },
        "check": {
          "kind": "result_verdict",
          "source": {
            "kind": "relay_result",
            "ref": "result"
          },
          "pass": ["accept", "accept-with-fold-ins"]
        },
        "routes": {
          "continue": "close-step",
          "pass": "close-step",
          "retry": "synthesize-step",
          "revise": "synthesize-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "close-step",
        "title": "Close — emit final result file",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-close@v1",
        "reads": ["reports/brief.json", "reports/compose.json", "reports/review-verdict.json"],
        "writes": {
          "report": {
            "path": "reports/explore-result.json",
            "schema": "explore.result@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["summary", "verdict_snapshot"]
        },
        "routes": {
          "complete": "@complete",
          "pass": "@complete",
          "stop": "@stop"
        }
      }
    ],
