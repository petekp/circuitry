    "blocks": [
      {
        "step_id": "frame-step",
        "title": "Frame — produce explore.brief",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-frame@v1",
        "reads": [],
        "writes": {
          "report": {
            "path": "reports/brief.json",
            "schema": "explore.brief@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["subject", "success_condition"]
        },
        "routes": {
          "continue": "analyze-step",
          "pass": "analyze-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "analyze-step",
        "title": "Analyze — produce explore.analysis",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-analyze@v1",
        "reads": ["reports/brief.json"],
        "writes": {
          "report": {
            "path": "reports/analysis.json",
            "schema": "explore.analysis@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["aspects"]
        },
        "routes": {
          "continue": "decision-options-step",
          "pass": "decision-options-step",
          "retry": "analyze-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "decision-options-step",
        "title": "Decision — draft tournament options",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-decision-options@v1",
        "reads": ["reports/brief.json", "reports/analysis.json"],
        "writes": {
          "report": {
            "path": "reports/decision-options.json",
            "schema": "explore.decision-options@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["decision_question", "options"]
        },
        "routes": {
          "continue": "proposal-fanout-step",
          "pass": "proposal-fanout-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "proposal-fanout-step",
        "title": "Decision — fan out option cases",
        "kind": "fanout",
        "executor": "orchestrator",
        "protocol": "explore-proposal-fanout@v1",
        "reads": ["reports/brief.json", "reports/decision-options.json"],
        "writes": {
          "branches_dir": "reports/tournament-branches",
          "aggregate": {
            "path": "reports/tournament-aggregate.json",
            "schema": "explore.tournament-aggregate@v1"
          }
        },
        "check": {
          "kind": "fanout_aggregate",
          "source": {
            "kind": "fanout_results",
            "ref": "aggregate"
          },
          "join": {
            "policy": "aggregate-survivors"
          },
          "verdicts": {
            "admit": ["accept"]
          }
        },
        "routes": {
          "continue": "stress-proposals-step",
          "pass": "stress-proposals-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "stress-proposals-step",
        "title": "Decision — stress proposals",
        "kind": "relay",
        "executor": "worker",
        "protocol": "explore-stress-proposals@v1",
        "reads": [
          "reports/brief.json",
          "reports/decision-options.json",
          "reports/tournament-aggregate.json"
        ],
        "writes": {
          "report": {
            "path": "reports/tournament-review.json",
            "schema": "explore.tournament-review@v1"
          },
          "request": "reports/relay/tournament-review.request.json",
          "receipt": "reports/relay/tournament-review.receipt.txt",
          "result": "reports/relay/tournament-review.result.json"
        },
        "check": {
          "kind": "result_verdict",
          "source": {
            "kind": "relay_result",
            "ref": "result"
          },
          "pass": ["recommend", "no-clear-winner", "needs-operator"]
        },
        "routes": {
          "continue": "tradeoff-checkpoint-step",
          "pass": "tradeoff-checkpoint-step",
          "revise": "decision-options-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "tradeoff-checkpoint-step",
        "title": "Decision — tradeoff checkpoint",
        "kind": "checkpoint",
        "executor": "orchestrator",
        "protocol": "explore-tradeoff-checkpoint@v1",
        "reads": ["reports/tournament-review.json", "reports/tournament-aggregate.json"],
        "writes": {
          "request": "reports/checkpoints/tradeoff-request.json",
          "response": "reports/checkpoints/tradeoff-response.json"
        },
        "check": {
          "kind": "checkpoint_selection",
          "source": {
            "kind": "checkpoint_response",
            "ref": "response"
          },
          "allow_from": {
            "kind": "policy_choices"
          }
        },
        "routes": {
          "continue": "decision-step",
          "pass": "decision-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "decision-step",
        "title": "Decision — compose final choice",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-decision@v1",
        "reads": [
          "reports/brief.json",
          "reports/decision-options.json",
          "reports/tournament-aggregate.json",
          "reports/tournament-review.json"
        ],
        "writes": {
          "report": {
            "path": "reports/decision.json",
            "schema": "explore.decision@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["decision", "selected_option_id", "rationale"]
        },
        "routes": {
          "continue": "close-tournament-step",
          "pass": "close-tournament-step",
          "stop": "@stop"
        }
      },
      {
        "step_id": "close-tournament-step",
        "title": "Close — emit tournament result file",
        "kind": "compose",
        "executor": "orchestrator",
        "protocol": "explore-close-tournament@v1",
        "reads": [
          "reports/brief.json",
          "reports/decision-options.json",
          "reports/tournament-aggregate.json",
          "reports/tournament-review.json",
          "reports/decision.json"
        ],
        "writes": {
          "report": {
            "path": "reports/explore-result.json",
            "schema": "explore.result@v1"
          }
        },
        "check": {
          "kind": "schema_sections",
          "source": {
            "kind": "report",
            "ref": "report"
          },
          "required": ["summary", "verdict_snapshot"]
        },
        "routes": {
          "complete": "@complete",
          "pass": "@complete",
          "stop": "@stop"
        }
      }
