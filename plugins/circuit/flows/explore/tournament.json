{
  "schema_version": "2",
  "id": "explore",
  "version": "0.1.0",
  "purpose": "Explore flow: frame the investigation, analyze the subject, either synthesize and critique findings or run a decision tournament, then close with findings plus evidence. All modes use Frame, Analyze, Plan or Decision, and Close; critique is embedded inside the Plan/Decision stage rather than exposed as a separate canonical Review stage.",
  "entry": {
    "signals": {
      "include": ["explore", "investigate", "research", "understand"],
      "exclude": []
    },
    "intent_prefixes": ["explore", "investigate", "decide"]
  },
  "axes": {
    "allowed_rigors": ["lite", "standard", "deep"],
    "supports_tournament": true,
    "supports_autonomous": true,
    "default": {
      "rigor": "standard",
      "tournament": false,
      "tournament_n": 3,
      "autonomous": false
    },
    "tournament_fan_out_stage": "decision-stage"
  },
  "starts_at": "frame-step",
  "stages": [
    {
      "id": "frame-stage",
      "title": "Frame",
      "canonical": "frame",
      "steps": ["frame-step"]
    },
    {
      "id": "analyze-stage",
      "title": "Analyze",
      "canonical": "analyze",
      "steps": ["analyze-step"]
    },
    {
      "id": "decision-stage",
      "title": "Plan or Decision",
      "canonical": "plan",
      "steps": [
        "decision-options-step",
        "proposal-fanout-step",
        "stress-proposals-step",
        "tradeoff-checkpoint-step",
        "decision-step"
      ]
    },
    {
      "id": "close-stage",
      "title": "Close",
      "canonical": "close",
      "steps": ["close-tournament-step"]
    }
  ],
  "stage_path_policy": {
    "mode": "partial",
    "omits": ["act", "verify", "review"],
    "rationale": "Explore is an investigation and decision flow. Synthesize, critique, and tournament stress review are all embedded inside the canonical Plan/Decision stage. Verify is omitted because Explore output is not executable and uses evidence/seam proof rather than mechanical command verification. See src/flows/explore/contract.md §Canonical stage set for the full rationale."
  },
  "steps": [
    {
      "id": "frame-step",
      "title": "Frame — produce explore.brief",
      "protocol": "explore-frame@v1",
      "reads": [],
      "routes": {
        "continue": "analyze-step",
        "pass": "analyze-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/brief.json",
          "schema": "explore.brief@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["subject", "success_condition"]
      }
    },
    {
      "id": "analyze-step",
      "title": "Analyze — produce explore.analysis",
      "protocol": "explore-analyze@v1",
      "reads": ["reports/brief.json"],
      "routes": {
        "continue": "decision-options-step",
        "pass": "decision-options-step",
        "retry": "analyze-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/analysis.json",
          "schema": "explore.analysis@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["aspects"]
      }
    },
    {
      "id": "decision-options-step",
      "title": "Decision — draft tournament options",
      "protocol": "explore-decision-options@v1",
      "reads": ["reports/brief.json", "reports/analysis.json"],
      "routes": {
        "continue": "proposal-fanout-step",
        "pass": "proposal-fanout-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/decision-options.json",
          "schema": "explore.decision-options@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["decision_question", "options"]
      }
    },
    {
      "id": "proposal-fanout-step",
      "title": "Decision — fan out option cases",
      "protocol": "explore-proposal-fanout@v1",
      "reads": ["reports/brief.json", "reports/decision-options.json"],
      "routes": {
        "continue": "stress-proposals-step",
        "pass": "stress-proposals-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "fanout",
      "branches": {
        "kind": "dynamic",
        "source_report": "reports/decision-options.json",
        "items_path": "options",
        "template": {
          "branch_id": "$item.id",
          "execution": {
            "kind": "relay",
            "role": "researcher",
            "goal": "$item.best_case_prompt",
            "report_schema": "explore.tournament-proposal@v1",
            "provenance_field": "option_id"
          }
        },
        "max_branches": {
          "kind": "axis",
          "axis": "tournament_n"
        },
        "required_count": {
          "kind": "axis",
          "axis": "tournament_n"
        }
      },
      "concurrency": {
        "kind": "bounded",
        "max": 2
      },
      "on_child_failure": "continue-others",
      "rubric": {
        "model_judgments_path": "rubric_model_judgments",
        "ordered_dims": [
          "evidence_rigor",
          "actionability",
          "coverage_adequacy",
          "scope_discipline",
          "honest_calibration",
          "project_specificity",
          "insight_density",
          "branch_distinctness"
        ],
        "runtime_signals": {
          "evidence_rigor": {
            "kind": "non_empty_array",
            "path": "evidence_refs"
          },
          "actionability": {
            "kind": "non_empty_string",
            "path": "next_action"
          },
          "coverage_adequacy": {
            "kind": "non_empty_string",
            "path": "case_summary"
          },
          "scope_discipline": {
            "kind": "constant",
            "signal": "met"
          },
          "honest_calibration": {
            "kind": "constant",
            "signal": "n/a"
          },
          "project_specificity": {
            "kind": "constant",
            "signal": "n/a"
          },
          "insight_density": {
            "kind": "constant",
            "signal": "n/a"
          },
          "branch_distinctness": {
            "kind": "constant",
            "signal": "n/a"
          }
        }
      },
      "writes": {
        "branches_dir": "reports/tournament-branches",
        "aggregate": {
          "path": "reports/tournament-aggregate.json",
          "schema": "explore.tournament-aggregate@v1"
        }
      },
      "check": {
        "kind": "fanout_aggregate",
        "source": {
          "kind": "fanout_results",
          "ref": "aggregate"
        },
        "join": {
          "policy": "aggregate-survivors"
        },
        "verdicts": {
          "admit": ["accept"]
        }
      }
    },
    {
      "id": "stress-proposals-step",
      "title": "Decision — stress proposals",
      "protocol": "explore-stress-proposals@v1",
      "reads": [
        "reports/brief.json",
        "reports/decision-options.json",
        "reports/tournament-aggregate.json"
      ],
      "routes": {
        "continue": "tradeoff-checkpoint-step",
        "pass": "tradeoff-checkpoint-step",
        "revise": "decision-options-step",
        "stop": "@stop"
      },
      "executor": "worker",
      "kind": "relay",
      "role": "reviewer",
      "writes": {
        "report": {
          "path": "reports/tournament-review.json",
          "schema": "explore.tournament-review@v1"
        },
        "request": "reports/relay/tournament-review.request.json",
        "receipt": "reports/relay/tournament-review.receipt.txt",
        "result": "reports/relay/tournament-review.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["recommend", "no-clear-winner", "needs-operator"]
      }
    },
    {
      "id": "tradeoff-checkpoint-step",
      "title": "Decision — tradeoff checkpoint",
      "protocol": "explore-tradeoff-checkpoint@v1",
      "reads": ["reports/tournament-review.json", "reports/tournament-aggregate.json"],
      "routes": {
        "continue": "decision-step",
        "pass": "decision-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "checkpoint",
      "policy": {
        "prompt": "Choose the option Circuit should close with. This checkpoint only supports final option choices; ask-for-more-evidence and stop routes are intentionally not encoded until the runtime has executable route semantics for them.",
        "choices_from": {
          "kind": "report_items",
          "source_report": "reports/tournament-aggregate.json",
          "items_path": "branches",
          "filter": {
            "kind": "path_equals",
            "path": "child_outcome",
            "value": "complete"
          },
          "id_path": "branch_id",
          "label_path": "result_body.option_label",
          "description_path": "result_body.case_summary"
        },
        "safe_default_choice": "option-1",
        "auto_resolution": {
          "policy": "highest-score",
          "source_report": "reports/tournament-aggregate.json",
          "branches_path": "branches",
          "id_path": "branch_id",
          "rubric_result_path": "rubric_result"
        }
      },
      "writes": {
        "request": "reports/checkpoints/tradeoff-request.json",
        "response": "reports/checkpoints/tradeoff-response.json"
      },
      "check": {
        "kind": "checkpoint_selection",
        "source": {
          "kind": "checkpoint_response",
          "ref": "response"
        },
        "allow_from": {
          "kind": "policy_choices"
        }
      }
    },
    {
      "id": "decision-step",
      "title": "Decision — compose final choice",
      "protocol": "explore-decision@v1",
      "reads": [
        "reports/brief.json",
        "reports/decision-options.json",
        "reports/tournament-aggregate.json",
        "reports/tournament-review.json"
      ],
      "routes": {
        "continue": "close-tournament-step",
        "pass": "close-tournament-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/decision.json",
          "schema": "explore.decision@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["decision", "selected_option_id", "rationale"]
      }
    },
    {
      "id": "close-tournament-step",
      "title": "Close — emit tournament result file",
      "protocol": "explore-close-tournament@v1",
      "reads": [
        "reports/brief.json",
        "reports/decision-options.json",
        "reports/tournament-aggregate.json",
        "reports/tournament-review.json",
        "reports/decision.json"
      ],
      "routes": {
        "complete": "@complete",
        "pass": "@complete",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/explore-result.json",
          "schema": "explore.result@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["summary", "verdict_snapshot"]
      }
    }
  ]
}
