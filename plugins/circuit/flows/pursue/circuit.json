{
  "schema_version": "2",
  "id": "pursue",
  "version": "0.1.0",
  "purpose": "Pursue flow: turn one or more rough operator ideas into pursuit contracts, coordinate their order, execute code-changing work serially, verify, review for interference, and close with evidence.",
  "entry": {
    "signals": {
      "include": ["pursue", "pursuit", "coordinate pursuits", "multiple autonomous goals"],
      "exclude": []
    },
    "intent_prefixes": ["pursue"]
  },
  "axes": {
    "allowed_rigors": ["standard"],
    "supports_tournament": false,
    "supports_autonomous": true,
    "default": {
      "rigor": "standard",
      "tournament": false,
      "tournament_n": 3,
      "autonomous": false
    }
  },
  "starts_at": "contract-step",
  "stages": [
    {
      "id": "frame-stage",
      "title": "Frame",
      "canonical": "frame",
      "steps": ["contract-step"]
    },
    {
      "id": "plan-stage",
      "title": "Coordinate",
      "canonical": "plan",
      "steps": ["graph-step", "wave-plan-step"]
    },
    {
      "id": "act-stage",
      "title": "Execute",
      "canonical": "act",
      "steps": ["batch-step"]
    },
    {
      "id": "verify-stage",
      "title": "Verify",
      "canonical": "verify",
      "steps": ["verify-step"]
    },
    {
      "id": "review-stage",
      "title": "Review",
      "canonical": "review",
      "steps": ["review-step"]
    },
    {
      "id": "close-stage",
      "title": "Close",
      "canonical": "close",
      "steps": ["close-step"]
    }
  ],
  "stage_path_policy": {
    "mode": "partial",
    "omits": ["analyze"],
    "rationale": "Pursuits V1 folds read-only discovery policy into the coordination graph before acting; a separate Analyze stage can be added when dynamic discovery fanout lands."
  },
  "steps": [
    {
      "id": "contract-step",
      "title": "Frame - create pursuit contract",
      "protocol": "pursuit-contract@v1",
      "reads": [],
      "routes": {
        "continue": "graph-step",
        "pass": "graph-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/pursuit/contract.json",
          "schema": "pursuit.contract@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["objective", "pursuits", "verification_command_candidates"]
      }
    },
    {
      "id": "graph-step",
      "title": "Coordinate - build pursuit graph",
      "protocol": "pursuit-graph@v1",
      "reads": ["reports/pursuit/contract.json"],
      "routes": {
        "continue": "wave-plan-step",
        "pass": "wave-plan-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/pursuit/graph.json",
          "schema": "pursuit.graph@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["nodes", "serial_groups", "parallel_read_only_groups"]
      }
    },
    {
      "id": "wave-plan-step",
      "title": "Plan - order execution waves",
      "protocol": "pursuit-wave-plan@v1",
      "reads": ["reports/pursuit/contract.json", "reports/pursuit/graph.json"],
      "routes": {
        "continue": "batch-step",
        "pass": "batch-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/pursuit/wave-plan.json",
          "schema": "pursuit.wave-plan@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["waves", "no_parallel_writes_reason"]
      }
    },
    {
      "id": "batch-step",
      "title": "Execute - run serialized pursuit batch",
      "protocol": "pursuit-batch@v1",
      "reads": [
        "reports/pursuit/graph.json",
        "reports/pursuit/contract.json",
        "reports/pursuit/wave-plan.json"
      ],
      "routes": {
        "continue": "verify-step",
        "pass": "verify-step",
        "retry": "batch-step",
        "stop": "@stop"
      },
      "executor": "worker",
      "kind": "relay",
      "role": "implementer",
      "writes": {
        "report": {
          "path": "reports/pursuit/batch.json",
          "schema": "pursuit.batch@v1"
        },
        "request": "reports/relay/pursuit-batch.request.json",
        "receipt": "reports/relay/pursuit-batch.receipt.txt",
        "result": "reports/relay/pursuit-batch.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["accept", "partial"]
      }
    },
    {
      "id": "verify-step",
      "title": "Verify - run Pursue proof commands",
      "protocol": "pursuit-verify@v1",
      "reads": ["reports/pursuit/contract.json", "reports/pursuit/batch.json"],
      "routes": {
        "continue": "review-step",
        "pass": "review-step",
        "retry": "batch-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "verification",
      "writes": {
        "report": {
          "path": "reports/pursuit/verification.json",
          "schema": "pursuit.verification@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["overall_status", "commands"]
      }
    },
    {
      "id": "review-step",
      "title": "Review - check pursuit coordination",
      "protocol": "pursuit-review@v1",
      "reads": [
        "reports/pursuit/contract.json",
        "reports/pursuit/batch.json",
        "reports/pursuit/verification.json"
      ],
      "routes": {
        "continue": "close-step",
        "pass": "close-step",
        "retry": "batch-step",
        "stop": "@stop"
      },
      "executor": "worker",
      "kind": "relay",
      "role": "reviewer",
      "writes": {
        "report": {
          "path": "reports/pursuit/review.json",
          "schema": "pursuit.review@v1"
        },
        "request": "reports/relay/pursuit-review.request.json",
        "receipt": "reports/relay/pursuit-review.receipt.txt",
        "result": "reports/relay/pursuit-review.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["clean", "needs-followup"]
      }
    },
    {
      "id": "close-step",
      "title": "Close - summarize pursuit result",
      "protocol": "pursuit-close@v1",
      "reads": [
        "reports/pursuit/contract.json",
        "reports/pursuit/graph.json",
        "reports/pursuit/wave-plan.json",
        "reports/pursuit/verification.json",
        "reports/pursuit/review.json",
        "reports/pursuit/batch.json"
      ],
      "routes": {
        "complete": "@complete",
        "pass": "@complete",
        "stop": "@stop",
        "handoff": "@handoff",
        "escalate": "@escalate"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/pursuit-result.json",
          "schema": "pursuit.result@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["summary", "outcome", "evidence_links"]
      }
    }
  ]
}
