{
  "schema_version": "2",
  "id": "migrate",
  "version": "0.1.0",
  "purpose": "Migrate flow: frame the source and target, inventory what needs to move, plan the coexistence window and rollback path, execute the migration through a child Build flow, verify nothing regressed, run a release review, and close with evidence. The first version runs one batch; broader batch orchestration can land once worktree support is ready.",
  "entry": {
    "signals": {
      "include": [
        "migrate",
        "migration",
        "framework-swap",
        "rewrite",
        "dependency-replacement",
        "architecture-transition"
      ],
      "exclude": []
    },
    "intent_prefixes": ["migrate", "rewrite"]
  },
  "entry_modes": [
    {
      "name": "default",
      "start_at": "frame-step",
      "depth": "standard",
      "description": "Default Migrate entry mode."
    },
    {
      "name": "deep",
      "start_at": "frame-step",
      "depth": "deep",
      "description": "Deep Migrate entry mode."
    },
    {
      "name": "autonomous",
      "start_at": "frame-step",
      "depth": "autonomous",
      "description": "Autonomous Migrate entry mode."
    }
  ],
  "stages": [
    {
      "id": "frame-stage",
      "title": "Frame",
      "canonical": "frame",
      "steps": ["frame-step"]
    },
    {
      "id": "inventory-stage",
      "title": "Inventory",
      "canonical": "analyze",
      "steps": ["inventory-step"]
    },
    {
      "id": "coexistence-stage",
      "title": "Coexistence Plan",
      "canonical": "plan",
      "steps": ["coexistence-step", "coexistence-checkpoint-step"]
    },
    {
      "id": "execute-stage",
      "title": "Batch Execution",
      "canonical": "act",
      "steps": ["batch-step"]
    },
    {
      "id": "verify-stage",
      "title": "Verify",
      "canonical": "verify",
      "steps": ["verify-step"]
    },
    {
      "id": "review-stage",
      "title": "Release Review",
      "canonical": "review",
      "steps": ["review-step"]
    },
    {
      "id": "close-stage",
      "title": "Close",
      "canonical": "close",
      "steps": ["close-step"]
    }
  ],
  "stage_path_policy": {
    "mode": "strict"
  },
  "steps": [
    {
      "id": "frame-step",
      "title": "Frame - produce Migrate brief",
      "protocol": "migrate-frame@v1",
      "reads": [],
      "routes": {
        "continue": "inventory-step",
        "pass": "inventory-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/migrate/brief.json",
          "schema": "migrate.brief@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["objective", "source", "target"]
      }
    },
    {
      "id": "inventory-step",
      "title": "Inventory - enumerate migration targets and group into batches",
      "protocol": "migrate-inventory@v1",
      "reads": ["reports/migrate/brief.json"],
      "routes": {
        "continue": "coexistence-step",
        "pass": "coexistence-step",
        "stop": "@stop"
      },
      "executor": "worker",
      "kind": "relay",
      "role": "implementer",
      "writes": {
        "report": {
          "path": "reports/migrate/inventory.json",
          "schema": "migrate.inventory@v1"
        },
        "request": "reports/relay/migrate-inventory.request.json",
        "receipt": "reports/relay/migrate-inventory.receipt.txt",
        "result": "reports/relay/migrate-inventory.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["accept"]
      }
    },
    {
      "id": "coexistence-step",
      "title": "Coexistence Plan - source/target side-by-side strategy and rollback path",
      "protocol": "migrate-coexistence@v1",
      "reads": ["reports/migrate/brief.json", "reports/migrate/inventory.json"],
      "routes": {
        "continue": "coexistence-checkpoint-step",
        "pass": "coexistence-checkpoint-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/migrate/coexistence.json",
          "schema": "migrate.coexistence@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["strategy", "switchover_criteria", "rollback_path"]
      }
    },
    {
      "id": "coexistence-checkpoint-step",
      "title": "Coexistence Plan - confirm migration path",
      "protocol": "migrate-coexistence-checkpoint@v1",
      "reads": ["reports/migrate/coexistence.json"],
      "routes": {
        "continue": "batch-step",
        "pass": "batch-step",
        "revise": "coexistence-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "checkpoint",
      "policy": {
        "prompt": "Confirm the coexistence plan before migration batch execution.",
        "choices": [
          {
            "id": "continue",
            "label": "Continue with the plan"
          },
          {
            "id": "revise",
            "label": "Revise the coexistence plan"
          },
          {
            "id": "stop",
            "label": "Stop before migration execution"
          }
        ],
        "safe_default_choice": "continue",
        "safe_autonomous_choice": "continue"
      },
      "writes": {
        "request": "reports/checkpoints/migrate-coexistence-request.json",
        "response": "reports/checkpoints/migrate-coexistence-response.json"
      },
      "check": {
        "kind": "checkpoint_selection",
        "source": {
          "kind": "checkpoint_response",
          "ref": "response"
        },
        "allow": ["continue", "revise", "stop"]
      }
    },
    {
      "id": "batch-step",
      "title": "Batch Execution - delegate the migration changes to a Build sub-run",
      "protocol": "migrate-batch@v1",
      "reads": ["reports/migrate/brief.json", "reports/migrate/inventory.json"],
      "routes": {
        "continue": "verify-step",
        "pass": "verify-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "sub-run",
      "flow_ref": {
        "flow_id": "build",
        "entry_mode": "default"
      },
      "goal": "Migrate the inventoried targets per migrate.coexistence@v1 batch plan",
      "depth": "standard",
      "writes": {
        "result": "reports/migrate/batch-result.json",
        "report": {
          "path": "reports/migrate/batch-result.json",
          "schema": "migrate.batch@v1"
        }
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "sub_run_result",
          "ref": "result"
        },
        "pass": ["accept", "accept-with-fixes"]
      }
    },
    {
      "id": "verify-step",
      "title": "Verify - run Migrate verification commands",
      "protocol": "migrate-verify@v1",
      "reads": ["reports/migrate/brief.json", "reports/migrate/batch-result.json"],
      "routes": {
        "continue": "review-step",
        "pass": "review-step",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "verification",
      "writes": {
        "report": {
          "path": "reports/migrate/verification.json",
          "schema": "migrate.verification@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["overall_status", "commands"]
      }
    },
    {
      "id": "review-step",
      "title": "Release Review - independent audit of the migration release",
      "protocol": "migrate-review@v1",
      "reads": [
        "reports/migrate/brief.json",
        "reports/migrate/batch-result.json",
        "reports/migrate/verification.json"
      ],
      "routes": {
        "continue": "close-step",
        "pass": "close-step",
        "stop": "@stop"
      },
      "executor": "worker",
      "kind": "relay",
      "role": "reviewer",
      "writes": {
        "report": {
          "path": "reports/migrate/review.json",
          "schema": "migrate.review@v1"
        },
        "request": "reports/relay/migrate-review.request.json",
        "receipt": "reports/relay/migrate-review.receipt.txt",
        "result": "reports/relay/migrate-review.result.json"
      },
      "check": {
        "kind": "result_verdict",
        "source": {
          "kind": "relay_result",
          "ref": "result"
        },
        "pass": ["release-approved", "release-with-followups"]
      }
    },
    {
      "id": "close-step",
      "title": "Close - emit Migrate result",
      "protocol": "migrate-close@v1",
      "reads": [
        "reports/migrate/brief.json",
        "reports/migrate/inventory.json",
        "reports/migrate/coexistence.json",
        "reports/migrate/batch-result.json",
        "reports/migrate/verification.json",
        "reports/migrate/review.json"
      ],
      "routes": {
        "complete": "@complete",
        "pass": "@complete",
        "stop": "@stop"
      },
      "executor": "orchestrator",
      "kind": "compose",
      "writes": {
        "report": {
          "path": "reports/migrate-result.json",
          "schema": "migrate.result@v1"
        }
      },
      "check": {
        "kind": "schema_sections",
        "source": {
          "kind": "report",
          "ref": "report"
        },
        "required": ["summary", "outcome", "evidence_links"]
      }
    }
  ]
}
