{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/handoff-packet.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "from_circuit",
    "to_circuit",
    "from_run_id",
    "artifact_refs",
    "summary_capsule",
    "open_questions",
    "accepted_risks"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "from_circuit": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "to_circuit": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "from_run_id": { "type": "string", "minLength": 1 },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^artifacts/.+\\.(md|json)$" }
    },
    "summary_capsule": { "type": "string", "minLength": 1 },
    "resume_hint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entry_mode": { "type": "string" },
        "start_at": { "type": "string" }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "accepted_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
