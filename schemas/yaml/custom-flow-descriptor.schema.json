{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.circuit.dev/yaml/custom-flow-descriptor.schema.json",
  "title": "Circuit custom flow descriptor",
  "description": "Descriptor emitted by circuit create next to a custom compiled flow package.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "format": {
      "type": "string",
      "const": "compiled-flow-package"
    },
    "compiled_flow": {
      "type": "string",
      "const": "circuit.json"
    },
    "archetype": {
      "type": "string",
      "const": "build"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["schema_version", "id", "format", "compiled_flow", "archetype", "purpose"],
  "additionalProperties": false
}
