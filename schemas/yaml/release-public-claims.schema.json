{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.circuit.dev/yaml/release-public-claims.schema.json",
  "title": "Circuit release public claims",
  "description": "Release ledger for public claims and their backing proof evidence.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "flow",
              "mode",
              "connector",
              "host",
              "safety",
              "proof",
              "first-run",
              "plan-execution",
              "customization",
              "docs"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["verified_current", "planned", "release_blocker", "approved_exception"]
          },
          "surfaces": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "backing": {
            "default": {
              "capability_ids": [],
              "proof_ids": [],
              "exception_ids": [],
              "test_paths": [],
              "script_checks": []
            },
            "type": "object",
            "properties": {
              "capability_ids": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "proof_ids": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "exception_ids": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "test_paths": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "script_checks": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "user_risk": {
            "type": "string",
            "minLength": 1
          },
          "readiness_refs": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^REL-[0-9]+$"
            }
          }
        },
        "required": ["id", "claim", "type", "status", "surfaces", "user_risk"],
        "additionalProperties": false
      }
    }
  },
  "required": ["schema_version", "claims"],
  "additionalProperties": false
}
