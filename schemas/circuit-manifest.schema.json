{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/circuit-manifest.schema.json",
  "title": "Circuit Manifest",
  "type": "object",
  "required": ["schema_version", "circuit"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "2" },
    "materialized_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "pattern": "^skills/[a-z0-9-]+/circuit\\.yaml$" },
        "git_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" }
      }
    },
    "circuit": {
      "type": "object",
      "required": ["id", "version", "purpose", "entry", "steps"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "version": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "purpose": { "type": "string", "minLength": 1 },
        "deprecated": { "type": "boolean" },
        "replaced_by": { "type": "string", "minLength": 1 },
        "entry": { "$ref": "#/$defs/entry" },
        "entry_modes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/entryMode" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        }
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["signals"],
      "additionalProperties": false,
      "properties": {
        "usage": {
          "type": "string",
          "pattern": "^<[a-z][a-z0-9-]*>$",
          "description": "Optional single placeholder suffix rendered after the derived /circuit:<slug> slash command in public surfaces, for example <task>."
        },
        "signals": {
          "type": "object",
          "required": ["include"],
          "additionalProperties": false,
          "properties": {
            "include": {
              "type": "array",
              "items": { "$ref": "#/$defs/signal" }
            },
            "exclude": {
              "type": "array",
              "items": { "$ref": "#/$defs/signal" }
            }
          }
        }
      }
    },
    "entryMode": {
      "type": "object",
      "required": ["start_at"],
      "additionalProperties": false,
      "properties": {
        "start_at": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "description": { "type": "string" },
        "rigor": {
          "type": "string",
          "enum": ["Lite", "Standard", "Deep", "Tournament", "Autonomous"],
          "description": "Named router rigor this entry mode maps to. Surfaces in active-run.md."
        }
      }
    },
    "signal": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "safeRelativePath": {
      "type": "string",
      "pattern": "^(?:[A-Za-z0-9{](?:[A-Za-z0-9_{}-]|\\.(?=[A-Za-z0-9_{}-]))*)(?:/(?:[A-Za-z0-9{](?:[A-Za-z0-9_{}-]|\\.(?=[A-Za-z0-9_{}-]))*))*$"
    },
    "safeRelativeJsonPath": {
      "type": "string",
      "pattern": "^(?:[A-Za-z0-9{](?:[A-Za-z0-9_{}-]|\\.(?=[A-Za-z0-9_{}-]))*)(?:/(?:[A-Za-z0-9{](?:[A-Za-z0-9_{}-]|\\.(?=[A-Za-z0-9_{}-]))*))*\\.json$"
    },
    "step": {
      "type": "object",
      "required": ["id", "title", "executor", "kind", "reads", "writes", "gate", "routes"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "title": { "type": "string", "minLength": 1 },
        "executor": { "enum": ["orchestrator", "worker"] },
        "kind": { "enum": ["synthesis", "checkpoint", "dispatch"] },
        "protocol": { "type": "string", "pattern": "^[a-z0-9-]+@v[0-9]+$" },
        "reads": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "#/$defs/readRef" }
            },
            {
              "type": "object",
              "required": ["any_of"],
              "additionalProperties": false,
              "properties": {
                "any_of": {
                  "type": "array",
                  "minItems": 2,
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/readRef" }
                  }
                }
              }
            }
          ]
        },
        "writes": { "$ref": "#/$defs/writes" },
        "gate": { "$ref": "#/$defs/gate" },
        "routes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/routeTarget" }
        },
        "budgets": { "$ref": "#/$defs/budgets" },
        "capabilities": { "$ref": "#/$defs/capabilities" },
        "checkpoint": { "$ref": "#/$defs/checkpoint" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "dispatch" } } },
          "then": {
            "required": ["protocol"],
            "properties": {
              "gate": {
                "type": "object",
                "required": ["kind"],
                "properties": {
                  "kind": { "const": "result_verdict" }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "checkpoint" } } },
          "then": {
            "required": ["protocol", "checkpoint"],
            "properties": {
              "writes": {
                "type": "object",
                "required": ["request", "response"],
                "properties": {
                  "request": {
                    "type": "string",
                    "pattern": "^checkpoints/[A-Za-z0-9._/{}-]*\\{attempt\\}[A-Za-z0-9._/{}-]*\\.json$"
                  },
                  "response": {
                    "type": "string",
                    "pattern": "^checkpoints/[A-Za-z0-9._/{}-]*\\{attempt\\}[A-Za-z0-9._/{}-]*\\.json$"
                  }
                }
              },
              "gate": {
                "type": "object",
                "required": ["kind", "source"],
                "properties": {
                  "kind": { "const": "checkpoint_selection" },
                  "source": {
                    "type": "string",
                    "pattern": "^checkpoints/[A-Za-z0-9._/{}-]*\\{attempt\\}[A-Za-z0-9._/{}-]*\\.json$"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "readRef": {
      "type": "string",
      "pattern": "^(optional:)?(user\\.task|repo\\.(snapshot|diff)|entry\\.[A-Za-z0-9._-]+|referenced:[A-Za-z0-9._-]+|artifacts/[A-Za-z0-9._/{}-]+\\.(md|json|ya?ml)|checkpoints/[A-Za-z0-9._/{}-]+\\.json|handoffs/[A-Za-z0-9._/{}-]+\\.json|jobs/[A-Za-z0-9._/{}-]+\\.json)$"
    },
    "writes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact": { "$ref": "#/$defs/artifactWrite" },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifactWrite" }
        },
        "request": { "$ref": "#/$defs/safeRelativeJsonPath" },
        "response": { "$ref": "#/$defs/safeRelativeJsonPath" },
        "receipt": { "$ref": "#/$defs/safeRelativeJsonPath" },
        "result": { "$ref": "#/$defs/safeRelativeJsonPath" },
        "handoff": { "$ref": "#/$defs/safeRelativeJsonPath" }
      }
    },
    "artifactWrite": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "pattern": "^artifacts/[A-Za-z0-9._/{}-]+\\.(md|json|ya?ml)$" },
        "schema": { "type": "string", "pattern": "^[a-z0-9-]+@v[0-9]+$" }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/capability" }
        },
        "optional": {
          "type": "array",
          "items": { "$ref": "#/$defs/capability" }
        }
      }
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"
    },
    "checkpoint": {
      "type": "object",
      "required": ["kind", "options"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
        },
        "materialize_artifact": { "type": "boolean" }
      }
    },
    "gate": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "source", "required"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "schema_sections" },
            "source": { "type": "string" },
            "required": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "alternate_source": { "type": "string" },
            "alternate_required": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "required_paths"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "all_outputs_present" },
            "required_paths": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "source", "allow"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "checkpoint_selection" },
            "source": { "type": "string" },
            "allow": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "source", "pass"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "result_verdict" },
            "source": { "type": "string" },
            "pass": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/verdict" }
            },
            "reroute": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/routeTarget" }
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "source", "minimum"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "option_count" },
            "source": { "type": "string" },
            "minimum": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "routeTarget": {
      "type": "string",
      "pattern": "^(@complete|@stop|@escalate|@handoff|[a-z0-9-]+)$"
    },
    "verdict": {
      "enum": [
        "analysis_ready",
        "audit_complete",
        "clean",
        "closed",
        "coexistence_invalidated",
        "complete_and_hardened",
        "contract_ready",
        "decision_packet_ready",
        "design_holds",
        "design_invalidated",
        "drafts_ready",
        "evidence_sufficient",
        "issues_found",
        "issues_remain",
        "map_complete",
        "needs_adjustment",
        "needs_more_exploration",
        "options_ready",
        "outputs_ready",
        "partial",
        "plan_ready",
        "pressure_complete",
        "queue_adjustment_required",
        "re_envision",
        "ready",
        "reroute",
        "reroute_execute",
        "reroute_plan",
        "repair_again",
        "retriage",
        "reviews_complete",
        "revise",
        "risk_boundary_invalidated",
        "ship_ready",
        "stable",
        "validation_complete",
        "verification_complete"
      ]
    }
  }
}
