{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/dispatch-request.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "circuit_id",
    "step_id",
    "attempt",
    "protocol",
    "capability_resolution_path",
    "inputs",
    "outputs",
    "budgets"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "run_id": { "type": "string", "minLength": 1 },
    "circuit_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "step_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "protocol": { "type": "string", "pattern": "^[a-z0-9-]+@v[0-9]+$" },
    "capability_resolution_path": { "type": "string", "pattern": "^jobs/[A-Za-z0-9._/-]+/capability-resolution\\.json$" },
    "inputs": {
      "type": "object",
      "required": ["artifact_paths", "prompt_path"],
      "additionalProperties": false,
      "properties": {
        "artifact_paths": {
          "type": "array",
          "items": { "type": "string", "pattern": "^artifacts/.+\\.md$" }
        },
        "prompt_path": { "type": "string", "pattern": "^jobs/[A-Za-z0-9._/-]+/prompt\\.md$" },
        "attachments": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["result_path", "stdout_path", "stderr_path"],
      "additionalProperties": false,
      "properties": {
        "result_path": { "type": "string", "pattern": "^jobs/[A-Za-z0-9._/-]+/job-result\\.json$" },
        "stdout_path": { "type": "string", "pattern": "^jobs/[A-Za-z0-9._/-]+/stdout\\.txt$" },
        "stderr_path": { "type": "string", "pattern": "^jobs/[A-Za-z0-9._/-]+/stderr\\.txt$" }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
