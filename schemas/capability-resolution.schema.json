{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/capability-resolution.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "circuit_id",
    "step_id",
    "declared",
    "resolution_order",
    "resolved",
    "unresolved_required",
    "unresolved_optional",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "run_id": { "type": "string", "minLength": 1 },
    "circuit_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "step_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "declared": {
      "type": "object",
      "required": ["required", "optional"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$" }
        },
        "optional": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$" }
        }
      }
    },
    "resolution_order": {
      "type": "array",
      "items": { "enum": ["project", "user", "builtin"] }
    },
    "resolved": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability", "provider_id", "source"],
        "additionalProperties": false,
        "properties": {
          "capability": { "type": "string" },
          "provider_id": { "type": "string", "minLength": 1 },
          "skill_path": { "type": "string" },
          "source": { "enum": ["project", "user", "builtin"] }
        }
      }
    },
    "unresolved_required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unresolved_optional": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": { "enum": ["complete", "degraded", "failed"] }
  }
}
