{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/checkpoint-response.schema.json",
  "type": "object",
  "required": ["schema_version", "run_id", "circuit_id", "step_id", "attempt", "selection", "resolved_at"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "run_id": { "type": "string", "minLength": 1 },
    "circuit_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "step_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "selection": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "notes": { "type": "string" },
    "resolved_at": { "type": "string", "format": "date-time" }
  }
}
