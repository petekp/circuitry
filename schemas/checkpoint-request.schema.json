{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/checkpoint-request.schema.json",
  "type": "object",
  "required": ["schema_version", "run_id", "circuit_id", "step_id", "attempt", "kind", "options", "prompt"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "run_id": { "type": "string", "minLength": 1 },
    "circuit_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "step_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "kind": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string", "pattern": "^artifacts/.+\\.md$" }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "prompt": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
