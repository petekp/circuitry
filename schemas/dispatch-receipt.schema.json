{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/dispatch-receipt.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "circuit_id",
    "step_id",
    "attempt",
    "protocol",
    "backend",
    "job_id",
    "submitted_at",
    "workspace"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "run_id": { "type": "string", "minLength": 1 },
    "circuit_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "step_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "protocol": { "type": "string", "pattern": "^[a-z0-9-]+@v[0-9]+$" },
    "backend": { "enum": ["codex", "agent", "custom"] },
    "job_id": { "type": "string", "minLength": 1 },
    "submitted_at": { "type": "string", "format": "date-time" },
    "workspace": { "enum": ["same-worktree", "worktree", "workspace-copy"] },
    "backend_metadata": { "type": "object" }
  }
}
