{
  "name": "@circuit/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "circuit-append-event": "dist/cli/append-event.js",
    "circuit-catalog-compiler": "dist/cli/catalog-compiler.js",
    "circuit-engine": "dist/cli/circuit-engine.js",
    "circuit-continuity": "dist/cli/continuity.js",
    "circuit-custom-circuits": "dist/cli/custom-circuits.js",
    "circuit-dispatch": "dist/cli/dispatch.js",
    "circuit-derive-state": "dist/cli/derive-state.js",
    "circuit-list-installed-surface-roots": "dist/cli/list-installed-surface-roots.js",
    "circuit-read-config": "dist/cli/read-config.js",
    "circuit-resume": "dist/cli/resume.js",
    "circuit-session-start": "dist/cli/session-start.js",
    "circuit-update-batch": "dist/cli/update-batch.js",
    "circuit-update-surface-manifest-schema": "dist/cli/update-surface-manifest-schema.js",
    "circuit-user-prompt-submit": "dist/cli/user-prompt-submit.js",
    "circuit-verify-install": "dist/cli/verify-install.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.config.mjs",
    "catalog": "node ../bin/catalog-compiler.js generate",
    "catalog:check": "node ../bin/catalog-compiler.js generate --check",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "prepare": "tsc && node esbuild.config.mjs",
    "prepare-ship": "node esbuild.config.mjs && npm run catalog",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.27.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
